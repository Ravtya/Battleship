@page "/game/{GameId}"
@rendermode InteractiveServer
@implements IDisposable
@inject BattleshipHubClient Hub
@inject UserSession Session
@inject NavigationManager Nav

<PageTitle>Battleship — Game</PageTitle>

<RequiresRegistration>
    @if (_state is null)
    {
        <p class="text-body-secondary text-center">Loading game...</p>
    }
    else
    {
        var waiting = _state.Phase == GamePhase.WaitingForOpponent;
        var placing = _state.Phase == GamePhase.PlacingShips;
        var inProgress = _state.Phase == GamePhase.InProgress;
        var finished = _state.Phase == GamePhase.Finished;
        var won = finished && _state.WinnerPlayerId == Session.PlayerId;
        var myTurn = inProgress && _state.CurrentTurnPlayerId == Session.PlayerId;
        var allShipsPlaced = ShipPlacement.IsComplete(_state.ShipConfiguration, _state.PlacedShipIds);

        <div class="mx-auto" style="max-width:1100px;">
            <h2 class="mb-1 text-center">Game @GameId</h2>
            @if (!finished && !waiting)
            {
                <p class="text-center @(_state.Phase == GamePhase.InProgress && myTurn ? "text-primary fw-semibold" : "text-body-secondary")">
                    @(_state.Phase switch
                    {
                        GamePhase.PlacingShips => "Place your fleet",
                        GamePhase.InProgress => myTurn ? "Your turn" : "Opponent's turn",
                        _ => ""
                    })
                </p>
            }

            @if (finished)
            {
                <GameFinishedBanner Won="won" OnBackToLobby='() => Nav.NavigateTo("/lobby")'/>
            }

            @if (waiting)
            {
                <div class="alert alert-info text-center">Waiting for an opponent to join your game.</div>
            }
            else if (placing)
            {
                <div class="card mb-3">
                    <div class="card-body">
                        <h5 class="card-title">Ship placement</h5>
                        <div class="d-flex flex-wrap gap-2 align-items-end mb-3">
                            <div>
                                <label class="form-label mb-1">Ship</label>
                                <select class="form-select" @bind="_selectedShipId"
                                        disabled="@_state.OwnPlacementComplete">
                                    @foreach (var ship in RemainingShips)
                                    {
                                        <option value="@ship.Id">@ship.Name (@ship.Length)</option>
                                    }
                                </select>
                            </div>
                            <button class="btn @(_horizontal ? "btn-primary" : "btn-outline-primary")"
                                    disabled="@_state.OwnPlacementComplete"
                                    @onclick="() => _horizontal = true">
                                Horizontal
                            </button>
                            <button class="btn @(!_horizontal ? "btn-primary" : "btn-outline-primary")"
                                    disabled="@_state.OwnPlacementComplete"
                                    @onclick="() => _horizontal = false">
                                Vertical
                            </button>
                            <button class="btn btn-outline-secondary" disabled="@_state.OwnPlacementComplete"
                                    @onclick="AutoPlace">Auto-place
                            </button>
                            <button class="btn btn-success" disabled="@(!allShipsPlaced || _state.OwnPlacementComplete)"
                                    @onclick="ConfirmPlacement">Confirm
                            </button>
                        </div>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-body">
                        <h5 class="card-title">Your fleet</h5>
                        <GameBoard Board="_state.OwnBoard"
                                   Clickable="!_state.OwnPlacementComplete && SelectedShip is not null"
                                   Preview="PreviewCells"
                                   PreviewValid="IsPreviewValid"
                                   HoverChanged="OnHoverChanged"
                                   OnClick="OnPlaceShip"/>
                    </div>
                </div>
            }
            else
            {
                <div class="row g-3 mb-3">
                    <div class="col-12 col-lg-6">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5 class="card-title text-center">Enemy board</h5>
                                <GameBoard Board="_state.EnemyBoard"
                                           Clickable="inProgress && myTurn"
                                           FireMode="true"
                                           OnClick="OnFire"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5 class="card-title text-center">Your board</h5>
                                <GameBoard Board="_state.OwnBoard"/>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (_state.RecentMoves.Count > 0)
            {
                <h5 class="text-center mb-2">Moves</h5>
                <ul class="list-group list-group-flush mb-3 small mx-auto text-center"
                    style="max-width:24rem; max-height:9rem; overflow-y:auto;">
                    @foreach (var m in _state.RecentMoves.AsEnumerable().Reverse())
                    {
                        <li class="list-group-item py-0 px-2 lh-sm border-0 border-bottom">
                            @m.PlayerName: (@m.Row,@m.Col) → @m.Result
                        </li>
                    }
                </ul>
            }

            @if (!finished)
            {
                <div class="d-flex justify-content-center gap-2 mb-3">
                    <button class="btn btn-outline-secondary" @onclick='() => Nav.NavigateTo("/lobby")'>Back to lobby
                    </button>
                </div>
            }

            @if (_error is not null)
            {
                <div class="alert alert-danger mb-0">@_error</div>
            }
        </div>
    }
</RequiresRegistration>

@code {
    [Parameter] public string GameId { get; set; } = "";

    private GameStateDto? _state;
    private string? _error;
    private IDisposable? _sub;
    private string? _selectedShipId;
    private bool _horizontal = true;
    private (int Row, int Col)? _hover;

    private IEnumerable<ShipDefinition> RemainingShips =>
        _state?.ShipConfiguration.Where(s => !_state.PlacedShipIds.Contains(s.Id)) ?? [];

    private ShipDefinition? SelectedShip =>
        _state?.ShipConfiguration.FirstOrDefault(s => s.Id == _selectedShipId) ?? RemainingShips.FirstOrDefault();

    private (HashSet<(int Row, int Col)> Cells, bool IsValid) PreviewData =>
        _state is null || SelectedShip is null || _hover is null
            ? ([], false)
            : ShipPlacement.Preview(
                _state.GridSize,
                SelectedShip,
                (_hover.Value.Row, _hover.Value.Col),
                _horizontal,
                _state.OwnBoard);

    private HashSet<(int Row, int Col)> PreviewCells => PreviewData.Cells;

    private bool IsPreviewValid => PreviewData.IsValid;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsRegistered) return;

        _sub = Hub.On<GameStateDto>("GameUpdated", s =>
        {
            if (s.GameId != GameId) return;
            _state = s;
            PickNextShip();
            _ = InvokeAsync(StateHasChanged);
        });

        await LoadState();
        PickNextShip();
    }

    private void PickNextShip()
    {
        if (_state is null) return;
        if (string.IsNullOrWhiteSpace(_selectedShipId) || _state.PlacedShipIds.Contains(_selectedShipId))
            _selectedShipId = RemainingShips.FirstOrDefault()?.Id;
    }

    private Task OnHoverChanged((int Row, int Col)? cell)
    {
        _hover = cell;
        return Task.CompletedTask;
    }

    private async Task LoadState() =>
        await HubPage.RunAsync(
            Hub,
            async () => _state = await Hub.InvokeAsync<GameStateDto>("GetGameState", GameId),
            message => _error = message);

    private Task InvokeGame(string method, params object?[] args) =>
        HubPage.RunAsync(Hub, () => Hub.InvokeAsync(method, [GameId, ..args]), message => _error = message);

    private async Task AutoPlace() => await InvokeGame("AutoPlace");

    private async Task ConfirmPlacement() => await InvokeGame("ConfirmPlacement");

    private async Task OnPlaceShip((int Row, int Col) pos)
    {
        if (_state is null || _state.OwnPlacementComplete || SelectedShip is null || !IsPreviewValid)
            return;

        await InvokeGame("PlaceShip", SelectedShip.Id, pos.Row, pos.Col, _horizontal);
    }

    private async Task OnFire((int Row, int Col) pos) => await InvokeGame("Fire", pos.Row, pos.Col);

    public void Dispose() => _sub?.Dispose();
}
