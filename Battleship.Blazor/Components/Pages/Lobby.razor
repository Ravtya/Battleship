@page "/lobby"
@rendermode InteractiveServer
@implements IDisposable
@inject BattleshipHubClient Hub
@inject UserSession Session
@inject NavigationManager Nav

<PageTitle>Battleship — Lobby</PageTitle>

<RequiresRegistration>
    <div class="mx-auto" style="max-width:640px;">
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-4">
            <h2 class="h4 text-body-secondary mb-0">Open games</h2>
            <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/game/create")'>Create game</button>
        </div>

        <p class="text-center text-body-secondary small mb-4">
            You: <span class="fw-semibold text-body">@Session.DisplayName</span>
        </p>

        @if (_games.Count == 0)
        {
            <div class="alert alert-info mb-0">No open games.</div>
        }
        else
        {
            <div class="list-group list-group-flush shadow-sm rounded overflow-hidden">
                @foreach (var game in _games)
                {
                    <div class="list-group-item d-flex align-items-center justify-content-between gap-3 py-3">
                        <div class="text-start">
                            <div class="fw-semibold">@game.HostName</div>
                            <div class="small text-body-secondary">@game.GridSize×@game.GridSize grid · @game.ShipCount ships</div>
                        </div>
                        <button class="btn btn-sm btn-outline-primary flex-shrink-0" @onclick="() => Join(game.GameId)">Join</button>
                    </div>
                }
            </div>
        }

        @if (_error is not null)
        {
            <div class="alert alert-danger mt-3 mb-0">@_error</div>
        }
    </div>
</RequiresRegistration>

@code {
    private List<LobbyGameDto> _games = [];
    private string? _error;
    private IDisposable? _sub;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsRegistered) return;

        _sub = Hub.On<List<LobbyGameDto>>("LobbyUpdated", games =>
        {
            _games = games.Where(g => g.HostId != Session.PlayerId).ToList();
            _ = InvokeAsync(StateHasChanged);
        });

        await LoadLobby();
    }

    private async Task LoadLobby() =>
        await HubPage.RunAsync(Hub, async () =>
        {
            var games = await Hub.InvokeAsync<List<LobbyGameDto>>("GetLobby");
            _games = games.Where(g => g.HostId != Session.PlayerId).ToList();
        }, message => _error = message);

    private async Task Join(string gameId) =>
        await HubPage.RunAsync(Hub, async () =>
        {
            await Hub.InvokeAsync("JoinGame", gameId);
            Nav.NavigateTo($"/game/{gameId}");
        }, message => _error = message);

    public void Dispose() => _sub?.Dispose();
}
