@inherits LayoutComponentBase
@inject UserSession Session

<header class="border-bottom bg-body-tertiary mb-4">
    <div class="container py-3 position-relative">
        @if (Session.IsRegistered)
        {
            <span class="position-absolute top-50 end-0 translate-middle-y badge rounded-pill text-bg-primary text-truncate"
                  style="max-width:45%;">
                @Session.DisplayName
            </span>
        }

        <h1 class="display-5 text-center mb-0">Battleship</h1>
    </div>
</header>

<main class="container pb-4">
    @Body
</main>

<div id="blazor-error-ui" data-nosnippet class="alert alert-danger m-3" style="display:none">
    An unhandled error has occurred.
    <a href="." class="alert-link ms-2">Reload</a>
    <span class="dismiss ms-2" role="button">x</span>
</div>
